{
  "name": "material-next-web-components",
  "private": true,
  "version": "0.1.0",
  "description": "Built-in Material Design web components and views for web products.",
  "main": "dist/material-next-home.js",
  "module": "dist/material-next-home.js",
  "type": "module",
  "scripts": {
    "build": "npm run build:scss && tsc",
    "build:watch": "tsc --watch",
    "clean": "rimraf dist docs custom-elements.json *.bundled.js",
    "lint": "npm run lint:lit-analyzer && npm run lint:eslint",
    "lint:eslint": "eslint 'src/**/*.ts'",
    "lint:lit-analyzer": "lit-analyzer",
    "format": "prettier .eleventy.cjs .eslintrc.json eslint.config.mjs .prettierrc.json .vscode/extensions.json CHANGELOG.md README.md index.html \"dev/**/*.html\" \"dev/**/*.md\" \"docs-src/**/*.{cjs,css,md,scss}\" \"src/**/*.{scss,ts}\" package.json tsconfig.json rollup.config.js web-dev-server.config.js web-test-runner.config.js --ignore-path ./.gitignore --write",
    "docs": "npm run docs:clean && npm run build && npm run analyze && npm run docs:build && npm run docs:assets && npm run docs:gen",
    "docs:clean": "rimraf docs",
    "docs:gen": "eleventy --config=.eleventy.cjs",
    "docs:gen:watch": "eleventy --config=.eleventy.cjs --watch",
    "docs:build": "rollup -c",
    "docs:assets": "npm run build:scss && cp docs-src/docs.css docs/",
    "docs:serve": "wds --root-dir=docs --node-resolve --watch",
    "analyze": "cem analyze --litelement --globs \"src/**/*.ts\"",
    "analyze:watch": "cem analyze --litelement --globs \"src/**/*.ts\" --watch",
    "serve": "wds --watch",
    "serve:prod": "MODE=prod npm run serve",
    "test": "npm run test:dev && npm run test:prod",
    "test:dev": "wtr",
    "test:watch": "wtr --watch",
    "test:prod": "MODE=prod wtr",
    "test:prod:watch": "MODE=prod wtr --watch",
    "checksize": "npm run build && rollup dist/material-next-home.js --file material-next-home.bundled.js --format esm --plugin @rollup/plugin-node-resolve | cat material-next-home.bundled.js | gzip -9 | wc -c ; rm -f material-next-home.bundled.js",
    "build:scss": "node scripts/build-scss.mjs",
    "postinstall": "patch-package",
    "smoke:exports": "npm run build && node scripts/smoke-exports.mjs"
  },
  "keywords": [
    "web-components",
    "lit-element",
    "typescript",
    "lit"
  ],
  "author": "Google LLC",
  "license": "BSD-3-Clause",
  "dependencies": {
    "@material/web": "^2.4.1",
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@open-wc/testing": "^4.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@types/mocha": "^10.0.10",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@web/dev-server": "^0.4.6",
    "@web/dev-server-legacy": "^2.1.1",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-playwright": "^0.11.1",
    "@webcomponents/webcomponentsjs": "^2.8.0",
    "eslint": "^10.5.0",
    "lit-analyzer": "^2.0.3",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "rollup": "^4.62.2",
    "rollup-plugin-summary": "^3.0.1",
    "sass": "^1.101.0",
    "typescript": "~6.0.3"
  },
  "customElements": "custom-elements.json",
  "overrides": {
    "js-yaml": "4.2.0"
  },
  "types": "dist/material-next-home.d.ts",
  "exports": {
    ".": {
      "types": "./dist/material-next-home.d.ts",
      "default": "./dist/material-next-home.js"
    },
    "./material-next-home.js": {
      "types": "./dist/material-next-home.d.ts",
      "default": "./dist/material-next-home.js"
    },
    "./code-block.js": {
      "types": "./dist/code-block.d.ts",
      "default": "./dist/code-block.js"
    },
    "./app-showcase.js": {
      "types": "./dist/app-showcase.d.ts",
      "default": "./dist/app-showcase.js"
    },
    "./expressive-tab-bar.js": {
      "types": "./dist/expressive-tab-bar.d.ts",
      "default": "./dist/expressive-tab-bar.js"
    },
    "./docs-page.js": {
      "types": "./dist/docs-page.d.ts",
      "default": "./dist/docs-page.js"
    },
    "./docs-shell.js": {
      "types": "./dist/docs-shell.d.ts",
      "default": "./dist/docs-shell.js"
    },
    "./docs-top-app-bar.js": {
      "types": "./dist/docs-top-app-bar.d.ts",
      "default": "./dist/docs-top-app-bar.js"
    },
    "./docs-vertical-tabs.js": {
      "types": "./dist/docs-vertical-tabs.d.ts",
      "default": "./dist/docs-vertical-tabs.js"
    },
    "./docs-table-of-contents.js": {
      "types": "./dist/docs-table-of-contents.d.ts",
      "default": "./dist/docs-table-of-contents.js"
    },
    "./docs/docs-page.js": {
      "types": "./dist/docs-page.d.ts",
      "default": "./dist/docs-page.js"
    },
    "./docs/docs-shell.js": {
      "types": "./dist/docs-shell.d.ts",
      "default": "./dist/docs-shell.js"
    },
    "./docs/docs-top-app-bar.js": {
      "types": "./dist/docs-top-app-bar.d.ts",
      "default": "./dist/docs-top-app-bar.js"
    },
    "./docs/docs-vertical-tabs.js": {
      "types": "./dist/docs-vertical-tabs.d.ts",
      "default": "./dist/docs-vertical-tabs.js"
    },
    "./docs/docs-table-of-contents.js": {
      "types": "./dist/docs-table-of-contents.d.ts",
      "default": "./dist/docs-table-of-contents.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "custom-elements.json"
  ]
}
